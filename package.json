{
  "name": "whatsapp-http-api",
  "version": "1.0.0",
  "description": "Full WhatsApp HTTP API powered by whatsapp-web.js",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "pm2:start": "pm2 start src/index.js --name whatsapp-api",
    "pm2:stop": "pm2 stop whatsapp-api",
    "pm2:restart": "pm2 restart whatsapp-api",
    "pm2:logs": "pm2 logs whatsapp-api"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "whatsapp-web.js": "^1.34.6"
  }
}
